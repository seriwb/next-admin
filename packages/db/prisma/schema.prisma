// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider               = "prisma-client"
  output                 = "./generated/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures        = ["fullTextSearchPostgres"]
}

// Admin account (Better Auth user table)
model Account {
  id            String   @id @default(uuid())
  email         String   @unique @db.Text()
  status        String   @db.Text()
  privilege     String   @db.Text()
  caution       String?  @db.Text() // suspended reason
  name          String?  @db.Text()
  image         String?  @db.Text()
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Better Auth relations
  sessions   BaSession[]
  baAccounts BaAccount[]

  @@map("account")
}

// Service user
model User {
  id        String   @id @default(uuid())
  email     String   @unique @db.Text()
  password  String   @db.Text()
  status    String   @db.Text()
  caution   String?  @db.Text() // suspended reason
  name      String?  @db.Text()
  image     String?  @db.Text()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  @@map("user")
}

model Article {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @db.Text()
  status      String    @default("draft") @db.Text()
  title       String    @default("") @db.Text()
  description String?   @db.Text()
  publishedAt DateTime? @map("published_at") @db.Timestamp()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp()

  @@map("article")
}

// Better Auth: Session table
model BaSession {
  id        String   @id
  expiresAt DateTime @map("expires_at") @db.Timestamp()
  token     String   @unique
  userId    String   @map("user_id") @db.Text()
  ipAddress String?  @map("ip_address") @db.Text()
  userAgent String?  @map("user_agent") @db.Text()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ba_session")
}

// Better Auth: Account (OAuth provider links) table
model BaAccount {
  id                    String    @id
  accountId             String    @map("account_id") @db.Text()
  providerId            String    @map("provider_id") @db.Text()
  userId                String    @map("user_id") @db.Text()
  accessToken           String?   @map("access_token") @db.Text()
  refreshToken          String?   @map("refresh_token") @db.Text()
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamp()
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamp()
  scope                 String?   @db.Text()
  password              String?   @db.Text()
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamp()

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ba_account")
}

// Better Auth: Verification table
model BaVerification {
  id         String   @id
  identifier String   @db.Text()
  value      String   @db.Text()
  expiresAt  DateTime @map("expires_at") @db.Timestamp()
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp()

  @@map("ba_verification")
}
